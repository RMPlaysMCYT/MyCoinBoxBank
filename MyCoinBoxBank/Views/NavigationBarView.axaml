<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:MyCoinBoxBank.Views"
             x:Class="MyCoinBoxBank.Views.NavigationBarView">
    
    <TabControl TabStripPlacement="Bottom" HorizontalAlignment="Stretch">
        <TabItem FontSize="20" Width="120" Height="50">
            <TabItem.Header>
                <TextBlock Text="Home" HorizontalAlignment="Center" >
                </TextBlock>
                </TabItem.Header>
            <views:HomeView/>
        </TabItem>

        <TabItem FontSize="20" Width="120" Height="50">
            <TabItem.Header>
                <TextBlock Text="Coins" HorizontalAlignment="Center" >
                </TextBlock>
            </TabItem.Header>
            <views:CoinsView/>
        </TabItem>

        <TabItem FontSize="20" Width="120" Height="50">
            <TabItem.Header>
                <TextBlock Text="Stats" HorizontalAlignment="Center" >
                </TextBlock>
            </TabItem.Header>
            <views:StatsView/>
        </TabItem>

        <TabItem FontSize="20" Width="120" Height="50">
            <TabItem.Header>
                <TextBlock Text="Settings" HorizontalAlignment="Center" >
                </TextBlock>
            </TabItem.Header>
            <views:SettingsView/>
        </TabItem>
    </TabControl>
</UserControl>